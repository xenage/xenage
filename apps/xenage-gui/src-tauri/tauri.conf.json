{
  "productName": "Xenage GUI",
  "version": "0.1.0",
  "identifier": "com.xenage.gui",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Xenage GUI",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://update.xenage.dev/update/{{target}}/{{current_version}}"
      ],
      "active": true,
      "pubkey": "PLACEHOLDER_PUBKEY"
    }
  }
}
