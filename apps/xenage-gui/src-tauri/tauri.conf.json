{
  "productName": "Xenage GUI",
  "version": "0.1.0",
  "identifier": "com.xenage.gui",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Xenage GUI",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xenage/xenage/releases/latest/download/latest.json"
      ],
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0Rjk5MzZCOTVCM0Y4OEEKUldTSytMT1ZhNVA1aE1CV0owN2JvVk5ad3RqZ0xVQ2kzcVFUM3gwWTJNUk92d041OFRLUTZwdHkK"
    }
  }
}
